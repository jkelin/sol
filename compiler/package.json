{
  "name": "@soljs/compiler",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkelin/sol.git",
    "directory": "compiler"
  },
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/vite.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun ../scripts/build-package.ts .",
    "prepublishOnly": "bun run build",
    "test": "bun test tests/compiler.test.ts tests/integration.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@babel/generator": "^7.28.4",
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.28.4",
    "@babel/types": "^7.28.4",
    "magic-string": "^0.30.21",
    "source-map-js": "^1.2.1"
  },
  "devDependencies": {
    "@soljs/sol": "0.1.0",
    "happy-dom": "^20.10.6"
  },
  "peerDependencies": {
    "vite": "^8.0.10"
  }
}
