{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "outDir": ".build/types",
    "rootDir": "src",
    "rewriteRelativeImportExtensions": true
  },
  "include": ["src"],
  "exclude": [".build", "dist", "tests"]
}
