{
  "name": "solix-workspace",
  "private": true,
  "workspaces": [
    "runtime",
    "compiler",
    "example",
    "web"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --cwd example dev",
    "dev:web": "bun run --cwd web dev",
    "build": "bun run --cwd example build",
    "build:example": "bun run --cwd example build",
    "build:example:inspect": "bun run --cwd example build:inspect",
    "build:web": "bun run --cwd web build",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "bun run lint:oxc && bun run lint:types",
    "lint:fix": "oxlint . --fix --deny-warnings",
    "lint:oxc": "oxlint . --deny-warnings",
    "lint:types": "oxlint . --type-aware --type-check --deny-warnings",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "test": "bun run --cwd runtime test && bun run --cwd compiler test && bun run --cwd web test",
    "test:web": "bun run --cwd web test",
    "test:e2e": "bun run build && bun run --cwd example test:e2e && bun run --cwd web test:e2e",
    "verify": "bun run format && bun run lint && bun run test"
  },
  "devDependencies": {
    "@babel/generator": "^7.28.4",
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.28.4",
    "@babel/types": "^7.28.4",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/bun": "latest",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "magic-string": "^0.30.21",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "source-map-js": "^1.2.1",
    "tailwindcss": "^4.1.14",
    "typescript": "^5",
    "valibot": "^1.4.2",
    "vite": "^8.0.10",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{css,html,js,jsx,json,jsonc,md,mjs,cjs,ts,tsx,yaml,yml}": "oxfmt --write"
  }
}
