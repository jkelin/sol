{
  "name": "@soljs/solkit",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jkelin/sol.git",
    "directory": "solkit"
  },
  "bin": {
    "solkit": "./src/cli.ts"
  },
  "type": "module",
  "module": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./vite": "./src/vite.ts",
    "./adapters/bun": "./src/adapters/bun.ts",
    "./adapters/node": "./src/adapters/node.ts",
    "./adapters/static": "./src/adapters/static.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && bun ../scripts/build-package.ts .",
    "prepublishOnly": "bun run build",
    "test": "bun test tests",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@soljs/sol": "0.1.0"
  },
  "devDependencies": {
    "vite": "^8.0.10"
  },
  "peerDependencies": {
    "vite": "^8.0.10"
  }
}
